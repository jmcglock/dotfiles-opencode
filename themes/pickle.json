{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg0": "#0D0B1A",
    "bg1": "#141025",
    "bg2": "#1C1733",
    "bg3": "#251E40",
    "fg0": "#E2D9F3",
    "fg1": "#C4B5D4",
    "fg2": "#9A89B0",
    "purple1": "#E9D5FF",
    "purple2": "#D8B4FE",
    "purple3": "#C084FC",
    "purple4": "#A78BFA",
    "purple5": "#8B5CF6",
    "purple6": "#7C3AED",
    "purple7": "#6D28D9",
    "purple8": "#5B21B6",
    "green": "#86EFAC",
    "red": "#FCA5A5",
    "yellow": "#FDE68A",
    "cyan": "#67E8F9"
  },
  "theme": {
    "primary": { "dark": "purple3", "light": "purple5" },
    "secondary": { "dark": "purple4", "light": "purple4" },
    "accent": { "dark": "purple2", "light": "purple6" },
    "error": { "dark": "red", "light": "red" },
    "warning": { "dark": "yellow", "light": "yellow" },
    "success": { "dark": "green", "light": "green" },
    "info": { "dark": "cyan", "light": "cyan" },
    "text": { "dark": "fg0", "light": "bg0" },
    "textMuted": { "dark": "fg2", "light": "fg2" },
    "background": { "dark": "bg0", "light": "fg0" },
    "backgroundPanel": { "dark": "bg1", "light": "fg1" },
    "backgroundElement": { "dark": "bg2", "light": "fg1" },
    "border": { "dark": "bg3", "light": "fg2" },
    "borderActive": { "dark": "purple5", "light": "purple5" },
    "borderSubtle": { "dark": "bg2", "light": "fg2" },
    "diffAdded": { "dark": "green", "light": "green" },
    "diffRemoved": { "dark": "red", "light": "red" },
    "diffContext": { "dark": "fg2", "light": "fg2" },
    "diffHunkHeader": { "dark": "purple4", "light": "purple4" },
    "diffHighlightAdded": { "dark": "green", "light": "green" },
    "diffHighlightRemoved": { "dark": "red", "light": "red" },
    "diffAddedBg": { "dark": "#1A2E1A", "light": "#E8F5E8" },
    "diffRemovedBg": { "dark": "#2E1A1A", "light": "#FDE8E8" },
    "diffContextBg": { "dark": "bg1", "light": "fg1" },
    "diffLineNumber": { "dark": "fg2", "light": "fg2" },
    "diffAddedLineNumberBg": { "dark": "#1A2E1A", "light": "#E8F5E8" },
    "diffRemovedLineNumberBg": { "dark": "#2E1A1A", "light": "#FDE8E8" },
    "markdownText": { "dark": "fg0", "light": "bg0" },
    "markdownHeading": { "dark": "purple2", "light": "purple6" },
    "markdownLink": { "dark": "purple4", "light": "purple5" },
    "markdownLinkText": { "dark": "purple3", "light": "purple4" },
    "markdownCode": { "dark": "green", "light": "green" },
    "markdownBlockQuote": { "dark": "fg2", "light": "fg2" },
    "markdownEmph": { "dark": "yellow", "light": "yellow" },
    "markdownStrong": { "dark": "purple1", "light": "purple6" },
    "markdownHorizontalRule": { "dark": "bg3", "light": "fg2" },
    "markdownListItem": { "dark": "purple3", "light": "purple5" },
    "markdownListEnumeration": { "dark": "purple4", "light": "purple4" },
    "markdownImage": { "dark": "purple4", "light": "purple5" },
    "markdownImageText": { "dark": "purple3", "light": "purple4" },
    "markdownCodeBlock": { "dark": "fg0", "light": "bg0" },
    "syntaxComment": { "dark": "fg2", "light": "fg2" },
    "syntaxKeyword": { "dark": "purple3", "light": "purple5" },
    "syntaxFunction": { "dark": "purple2", "light": "purple6" },
    "syntaxVariable": { "dark": "cyan", "light": "cyan" },
    "syntaxString": { "dark": "green", "light": "green" },
    "syntaxNumber": { "dark": "yellow", "light": "yellow" },
    "syntaxType": { "dark": "purple4", "light": "purple4" },
    "syntaxOperator": { "dark": "purple3", "light": "purple5" },
    "syntaxPunctuation": { "dark": "fg1", "light": "bg0" }
