{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-claude-auth@latest",
    "opencode-notificator",
    "opencode-dynamic-context-pruning",
    "opencode-wakatime",
    "opencode-type-inject"
  ],
  "model": "xai/grok-4.5",
  "small_model": "anthropic/claude-sonnet-4-6",
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "git push *": "ask",
      "git reset --hard*": "ask"
    }
  },
  "compaction": { "prune": true, "tail_turns": 3 },
  "agent": {
    "compaction": { "model": "anthropic/claude-sonnet-4-6" },
    "title": {
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.2,
      "prompt": "{file:./prompts/title.txt}"
    },
    "summary": { "model": "anthropic/claude-sonnet-4-6" }
  },
  "mcp": {
    "context7": { "type": "remote", "url": "https://mcp.context7.com/mcp" },
    "gh_grep": { "type": "remote", "url": "https://mcp.grep.app" }
  },
  "references": {
    "opencode": {
      "repository": "anomalyco/opencode",
      "branch": "dev",
      "description": "OpenCode source — use for plugin/hook/API questions"
    }
  }
}
