{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-claude-auth@latest"],
  "model": "xai/grok-4.5",
  "small_model": "anthropic/claude-sonnet-4-6",
  "share": "manual",
  "autoupdate": true,
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "webfetch": "allow"
  },
  "formatter": true,
  "lsp": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3
  },
  "tool_output": {
    "max_lines": 1500,
    "max_bytes": 40960
  },
  "agent": {
    "compaction": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "title": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "summary": {
      "model": "anthropic/claude-sonnet-4-6"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}
